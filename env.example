# ==== Supabase (client-safe, exposed to the browser) ====
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ==== ORBIT auth (SERVER-ONLY — set in Netlify env, never VITE_ prefixed) ====
# Custom OTP-based signup/login/reset — see netlify/functions/auth.ts. Supabase
# is used only as Postgres here; Supabase Auth is not used at all.

# Project Settings -> API -> JWT Settings -> Legacy JWT Secret. Tokens are
# signed with this so RLS (auth.uid()) keeps working exactly as before.
SUPABASE_JWT_SECRET=

# Project Settings -> API -> service_role key. Lets the auth function read/
# write public.users and public.otp_codes, which have no client-facing RLS
# policy on purpose. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# How long a session lasts before the user has to sign in again.
AUTH_TOKEN_TTL_DAYS=30

# The site's own public origin — needed server-side because Netlify functions
# (e.g. team invite emails) build absolute links and can't reliably infer this
# from the request. No trailing slash.
PUBLIC_SITE_URL=https://orbitdev.work

# ==== Transactional mail (SERVER-ONLY) ====
# Sends the verification code, password-reset code, and "new sign-in" alert
# emails from ORBIT's own mailbox (Gmail SMTP + app password). For local
# `netlify dev` you can instead drop a netlify/functions/mail-config.json —
# see mail-config.example.json.
MAIL_USER=orbit@yourdomain.com
MAIL_APP_PASSWORD=16-character app password, no spaces
MAIL_FROM=ORBIT <orbit@yourdomain.com>

# ==== Local companion agent ====
# Local dev: use http. Deployed HTTPS site: use an https:// URL (mkcert).
# You can also change this live in ORBIT > Settings > Agent URL.
VITE_AGENT_URL=http://localhost:47600

# ==== Zoho Sprints — NOT an env var ====
# Deliberately no ZOHO_* here: Zoho credentials are per-account only, entered
# in ORBIT -> Settings -> Zoho Sprints (stored in the `integrations` table,
# RLS-scoped to that account). netlify/functions/zoho-sprints.ts has no
# environment-variable fallback, so nothing is shared across accounts.
