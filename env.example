# ==== Supabase (client-safe, exposed to the browser) ====
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ==== Local companion agent ====
# Local dev: use http. Deployed HTTPS site: use an https:// URL (mkcert).
# You can also change this live in ORBIT > Settings > Agent URL.
VITE_AGENT_URL=http://localhost:47600

# ==== Zoho Sprints (SERVER-ONLY — set in Netlify env, never VITE_ prefixed) ====
# IMPORTANT: put values bare. No inline "# comments", no quotes, no trailing spaces.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Data center: in | com | eu | com.au | jp | sa | com.cn
ZOHO_DC=in

# Optional but recommended — pin your team/project so the app doesn't auto-discover.
# Values must be bare (a comment on the same line becomes part of the value!).
ZOHO_TEAM_ID=60069474422
ZOHO_PROJECT_ID=45354000001026097
