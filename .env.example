# ==== Supabase (client-safe, exposed to the browser) ====
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ==== Local companion agent ====
# Local dev: http. Deployed HTTPS site: an https:// URL (mkcert).
# Can also be changed live in ORBIT > Settings > Agent URL.
VITE_AGENT_URL=http://localhost:47600

# ==== Error tracking (Orbit's own crash reporting, not the Sentry *integration* ====
# ==== in Settings — that's a separate, per-user, read-your-own-issues feature) ====
# Optional but recommended for production: without it, Orbit has zero
# visibility into client-side render/runtime errors. Leave blank for local
# dev — see src/lib/errorReporting.ts.
VITE_SENTRY_DSN=

# ==== Integrations are configured in the app, not here ====
# Zoho Sprints and Gmail keys are entered per-user in ORBIT > Settings and
# stored in the database (integrations table). You do NOT need to set them here.
#
# The ZOHO_* variables below are an OPTIONAL fallback: if a user has no keys
# saved in Settings, the server function uses these instead. Leave them blank
# for a pure multi-user setup. If you do use them, keep values bare — no inline
# "# comments", no quotes, no trailing spaces.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DC=in
ZOHO_TEAM_ID=
ZOHO_PROJECT_ID=
