# --- Supabase (client-safe, exposed to the browser) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Local companion agent (launches VS Code / Visual Studio) ---
VITE_AGENT_URL=https://localhost:47600

# --- Zoho Sprints (SERVER-ONLY — set in Netlify env, never VITE_ prefixed) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_DC=in                 # your data center: in | com | eu | com.au | jp | sa | com.cn

# Optional — skip auto-discovery by pinning these (recommended once known):
# ZOHO_TEAM_ID=            # portals[0].zsoid from GET /zsapi/teams/
# ZOHO_PROJECT_ID=         # numeric project id
# ZOHO_PROJECT_NAME=meritech   # or match a project by name substring
